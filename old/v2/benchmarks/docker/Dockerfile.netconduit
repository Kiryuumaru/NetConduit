FROM mcr.microsoft.com/dotnet/nightly/sdk:10.0 AS build
WORKDIR /repo
COPY src/ src/
COPY benchmarks/Directory.Build.props benchmarks/Directory.Build.props
COPY benchmarks/docker/netconduit-comparison/ benchmarks/docker/netconduit-comparison/
RUN dotnet restore benchmarks/docker/netconduit-comparison/NetConduit.ComparisonBench.csproj --nologo
RUN dotnet publish benchmarks/docker/netconduit-comparison/NetConduit.ComparisonBench.csproj \
    -c Release -f net10.0 -o /app --nologo -p:ErrorOnDuplicatePublishOutputFiles=false

FROM mcr.microsoft.com/dotnet/nightly/runtime:10.0
COPY --from=build /app /app
WORKDIR /app
ENTRYPOINT ["dotnet", "NetConduit.ComparisonBench.dll"]
