<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<LangVersion>preview</LangVersion>
		<TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IsAotCompatible>true</IsAotCompatible>
		<EnableTrimAnalyzer>true</EnableTrimAnalyzer>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<UseLocalNetConduit Condition="'$(UseLocalNetConduit)' == '' and '$(Configuration)' == 'Debug'">true</UseLocalNetConduit>
		<UseLocalNetConduit Condition="'$(UseLocalNetConduit)' == '' and '$(Configuration)' != 'Debug'">false</UseLocalNetConduit>
	</PropertyGroup>

	<!-- NuGet Package Metadata -->
	<PropertyGroup>
		<PackageId>NetConduit.Transit.DeltaMessage</PackageId>
		<Authors>Kiryuumaru</Authors>
		<Company>Kiryuumaru</Company>
		<Copyright>Kiryuumaru</Copyright>
		<Description>Delta message transit for NetConduit. Synchronizes state by sending only changed fields after an initial full sync, minimizing bandwidth.</Description>
		<PackageTags>multiplexer;stream;delta;json;transit;networking;async;aot</PackageTags>
		<PackageProjectUrl>https://github.com/Kiryuumaru/NetConduit</PackageProjectUrl>
		<RepositoryUrl>https://github.com/Kiryuumaru/NetConduit.git</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageLicenseFile>LICENSE</PackageLicenseFile>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\..\README.md" Pack="true" PackagePath="\" />
		<None Include="..\..\LICENSE" Pack="true" PackagePath="\" />
	</ItemGroup>

	<ItemGroup Condition="'$(UseLocalNetConduit)' == 'true'">
		<ProjectReference Include="..\NetConduit\NetConduit.csproj" />
	</ItemGroup>

	<ItemGroup Condition="'$(UseLocalNetConduit)' != 'true'">
		<PackageReference Include="NetConduit" Version="3.0.1" />
	</ItemGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="NetConduit.Transit.DeltaMessage.UnitTests" />
	</ItemGroup>

</Project>
